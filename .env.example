DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
API_KEY=your_global_api_key
JWT_SECRET=change_me
JWT_TTL=43200

# Cashfree Payment Gateway (use SANDBOX for test credentials)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=SANDBOX
# Optional: return URL after web checkout (must be whitelisted in Cashfree dashboard)
# CASHFREE_RETURN_URL=https://yoursite.com/payment/return

# Cashfree Secure ID (Verification Suite)
# If omitted, backend falls back to CASHFREE_APP_ID/CASHFREE_SECRET_KEY.
CASHFREE_VRS_CLIENT_ID=
CASHFREE_VRS_CLIENT_SECRET=
# Optional (for DigiLocker create URL redirect)
# CASHFREE_SECUREID_DIGILOCKER_REDIRECT_URL=https://yourapp.com/kyc/digilocker/return
# Optional (recommended) webhook signature secret from Secure ID webhook settings
# CASHFREE_SECUREID_WEBHOOK_SECRET=
