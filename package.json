{
  "name": "excellent-finserv-backend-node",
  "version": "1.0.0",
  "description": "Node.js + TypeScript backend mirroring the Laravel backend in exf",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "postinstall": "prisma generate && npm run build",
    "start": "node dist/index.js",
    "migrate:regno": "npx tsx prisma/scripts/migrate-regno-to-ex.ts",
    "migrate:regno:dry": "npx tsx prisma/scripts/migrate-regno-to-ex.ts --dry-run",
    "prisma:sync-checksums": "node prisma/scripts/sync-migration-checksums.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.7.0",
    "@prisma/client": "^6.7.0",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "prisma": "^6.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
